# Copy to .env and fill in. Never commit .env.

# Google AI Studio API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=

# Gemini Live-capable model id (half-cascade default for function-calling
# reliability; gemini-live-2.5-flash-native-audio for native-audio voice quality)
LIVE_MODEL=gemini-3.1-flash-live-preview

# Session persistence (in-memory by default; Redis optional, see ADR-003)
USE_REDIS=false
REDIS_URL=redis://localhost:6379

# DuckDB recipe database (Phase 5)
RECIPES_DB_PATH=data/recipes.db
